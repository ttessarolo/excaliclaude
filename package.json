{
  "name": "excaliclaude",
  "version": "0.1.0",
  "description": "Interactive visual collaboration between human and Claude on a shared Excalidraw canvas. MCP server + Excalidraw frontend + native window.",
  "type": "module",
  "main": "dist/mcp/index.js",
  "bin": {
    "excaliclaude-mcp": "dist/mcp/index.js"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:frontend",
    "build:server": "tsc",
    "build:frontend": "vite build",
    "dev": "concurrently \"npm run dev:server\" \"vite\"",
    "dev:server": "tsc --watch",
    "dev:mcp": "tsx watch src/mcp/index.ts",
    "dev:canvas": "tsx watch src/canvas-app/start-server.ts",
    "type-check": "tsc --noEmit",
    "start": "node dist/mcp/index.js"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@excalidraw/mermaid-to-excalidraw": "^1.1.3",
    "@modelcontextprotocol/sdk": "latest",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mermaid": "^11.12.1",
    "node-fetch": "^3.3.2",
    "open": "^10.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "winston": "^3.11.0",
    "ws": "^8.14.2",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.22.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.6.0",
    "bun-types": "^1.3.12",
    "concurrently": "^9.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "webview-bun": "^2.4.0"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "excalidraw",
    "claude-code",
    "plugin",
    "canvas",
    "visual-collaboration",
    "diagram",
    "whiteboard"
  ],
  "author": {
    "name": "ttessarolo"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "skills",
    ".claude-plugin",
    ".mcp.json",
    "README.md",
    "LICENSE"
  ]
}
